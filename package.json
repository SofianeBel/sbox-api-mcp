{
  "name": "sbox-api-mcp",
  "version": "1.1.0",
  "description": "MCP server for S&box game engine API documentation and Workshop (UGC) asset search. Search types, methods, properties, documentation, and community-made models, sounds, maps, and more.",
  "type": "module",
  "bin": {
    "sbox-api-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    ".claude-plugin",
    ".mcp.json"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts"
  },
  "keywords": [
    "mcp",
    "sbox",
    "sandbox",
    "game-engine",
    "api",
    "documentation",
    "claude",
    "claude-code",
    "ugc",
    "workshop",
    "assets",
    "models"
  ],
  "author": "sofianebel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sofianebel/sbox-api-mcp.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "fuse.js": "^7.1.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
